# =================================================
# 平台与硬件核心 (Netcore N60 Pro / MT7986)
# =================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7986=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_netcore_n60-pro=y

# =================================================
# LuCI 基础与中文支持 (解决无界面、无中文问题)
# =================================================
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# =================================================
# 主题设置 (解决外观设置问题)
# =================================================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# =================================================
# 防火墙 (纯 nft 架构 + 核心兼容层)
# =================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nf-flow=y

# 核心兼容层：将旧插件指令翻译至 nft (避免冲突且保持兼容)
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y

# 禁用传统内核级 iptables
# CONFIG_PACKAGE_iptables is not set
# CONFIG_PACKAGE_kmod-ipt-core is not set

# =================================================
# WiFi (MTK 闭源驱动 + 界面控制)
# =================================================
CONFIG_MTK_WIFI_DRIVER=y
CONFIG_MTK_MT_WIFI=y
CONFIG_MTK_WIFI_BASIC_FUNC=y
CONFIG_MTK_WIFI_MODE_AP=y
CONFIG_MTK_DBDC_MODE=y

# 关键：补全 MTK 闭源驱动专用 LuCI 菜单
CONFIG_PACKAGE_mtwifi-cfg=y
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y
CONFIG_PACKAGE_luci-i18n-mtwifi-cfg-zh-cn=y

# 安全与性能优化
CONFIG_MTK_WPA3_SUPPORT=y
CONFIG_MTK_TXBF_SUPPORT=y
CONFIG_MTK_MU_RA_SUPPORT=y
CONFIG_MTK_GREENAP_SUPPORT=y
CONFIG_MTK_MBSS_SUPPORT=y

# WiFi 配套依赖
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_kmod-cfg80211=y

# =================================================
# 网络插件 (OpenClash & AdGuard Home)
# =================================================
# OpenClash (建议开启 Meta 内核 + TUN 模式)
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_ip-full=y

# AdGuard Home
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# VPN (WireGuard)
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-i18n-wireguard-zh-cn=y

# =================================================
# 硬件加速与性能 (MTK 平台灵魂)
# =================================================
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn=y
CONFIG_PACKAGE_luci-app-eqos-mtk=y

# =================================================
# USB / 存储 / zram (针对 N60 Pro 优化)
# =================================================
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# =================================================
# 系统工具与终端
# =================================================
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openssl-util=y

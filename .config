# =============================
# 基础平台
# =============================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7986=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_netcore_n60-pro=y

# =============================
# LuCI
# =============================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-argon=y

# =============================
# 防火墙（纯 nft）
# =============================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
# CONFIG_PACKAGE_iptables is not set
# CONFIG_PACKAGE_kmod-ipt-core is not set

# =============================
# WiFi（MTK 官方最稳方案）
# ⚠️ 只保留驱动包，禁止手写 MTK 宏
# =============================
CONFIG_PACKAGE_kmod-mt_wifi=y
CONFIG_PACKAGE_kmod-conninfra=y

# =============================
# 网络 / 科学 / DNS
# =============================
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_ip-full=y

CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y

CONFIG_PACKAGE_luci-app-wireguard=y

# ❌ 避免冲突
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set

# =============================
# 硬件加速（MTK 必开）
# =============================
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nf-flow=y

CONFIG_PACKAGE_irqbalance=y

# =============================
# USB / 存储 / swap
# =============================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y

CONFIG_PACKAGE_block-mount=y

CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y

CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# =============================
# 终端 / 工具
# =============================
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_dropbear=y

CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_nano=y

CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_openssl-util=y

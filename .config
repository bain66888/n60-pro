# ========================================

# 目标平台

# ========================================

CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y

# ========================================

# 核心系统工具

# ========================================

CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_dropbear=y          # 可选轻量 SSH
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE-ip-full=y
CONFIG_PACKAGE-ipset=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_cjson=y
CONFIG_PACKAGE_jq=y

# 文件系统驱动

CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ========================================

# LuCI & Web管理

# ========================================

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-json=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-mtk=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-proto-wireguard=y

# ========================================

# 防火墙 & NAT

# ========================================

CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_iptables-mod-nat-extra=y
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y
CONFIG_PACKAGE_dnsmasq-full=y

# ========================================

# 硬件加速 / 高性能

# ========================================

CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_irqbalance=y

# ========================================

# WiFi 驱动 & 工具

# ========================================

CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_wireless-tools=y
CONFIG_PACKAGE_wpa-supplicant=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw=y

# ========================================

# Docker（可选）

# ========================================

# CONFIG_PACKAGE_docker=y

# ========================================

# OpenClash & Passwall 依赖

# ========================================

CONFIG_PACKAGE_passwall=y
CONFIG_PACKAGE_trojan-go=y
CONFIG_PACKAGE_v2ray-core=y
CONFIG_PACKAGE_xray-core=y

# ========================================

# VPN

# ========================================

CONFIG_PACKAGE_wireguard=y
CONFIG_PACKAGE_wireguard-tools=y

# ========================================

# ZeroTier

# ========================================

CONFIG_PACKAGE_zerotier=y

# ========================================

# UPnP

# ========================================

CONFIG_PACKAGE_upnpd=y

# ========================================

# 终端 / Web 终端

# ========================================

CONFIG_PACKAGE_ttyd=y

# ========================================

# 性能优化 & 调试工具

# ========================================

CONFIG_PACKAGE_ping=y
CONFIG_PACKAGE_traceroute=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_net-tools=y
CONFIG_PACKAGE_coreutils-ls=y
CONFIG_PACKAGE_coreutils-stat=y
CONFIG_PACKAGE_coreutils-sort=y
CONFIG_PACKAGE_iw=y
